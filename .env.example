# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_from_botfather

# ── Flow — Crypto Payments (flow.vylth.com) ─────────────────────────
# Sign up at https://flow.vylth.com → API Keys → Create Key
FLOW_API_KEY=fl_your_api_key
FLOW_API_SECRET=your_api_secret

# (Optional) For sending crypto payouts to users
# Go to Settings → Vendor Keys to generate these
FLOW_VENDOR_KEY=
FLOW_VENDOR_SECRET=

# (Optional) Verify webhook signatures — found in your API key settings
FLOW_WEBHOOK_SECRET=

# ── Webhook Server ───────────────────────────────────────────────────
# Public URL where Flow sends payment notifications
# Must be HTTPS in production (use ngrok for local dev)
WEBHOOK_URL=https://yourdomain.com/webhook/flow
WEBHOOK_PORT=8080
